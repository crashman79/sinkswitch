[Desktop Entry]
Type=Application
Name=Audio Router Tray Icon
Comment=System tray icon for PipeWire/PulseAudio audio routing
Icon=audio-card
Exec=~/.config/pipewire-router/launch-tray-icon.sh
StartupNotify=true
Categories=Audio;System;
OnlyShowIn=KDE;GNOME;XFCE;MATE;

# KDE specific
X-KDE-StartupNotify=true
